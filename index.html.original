const SERVICES = [
  { name:'General Banking',   c:{closedBiz: 62,genOpp:42,strengthRel: 95,providedInfo:65,nextSteps:44,didNotAch:34,noShow:21,cancelled:18,doNotTrack:28}, prev:369 },
  { name:'Mortgage',          c:{closedBiz: 78,genOpp:52,strengthRel: 68,providedInfo:46,nextSteps:31,didNotAch:25,noShow:15,cancelled:13,doNotTrack:17}, prev:308 },
  { name:'Investments',       c:{closedBiz: 65,genOpp:43,strengthRel: 72,providedInfo:49,nextSteps:33,didNotAch:26,noShow:16,cancelled:14,doNotTrack:19}, prev:314 },
  { name:'Loans',             c:{closedBiz: 52,genOpp:35,strengthRel: 61,providedInfo:42,nextSteps:28,didNotAch:22,noShow:14,cancelled:11,doNotTrack:17}, prev:271 },
  { name:'Credit Cards',      c:{closedBiz: 38,genOpp:25,strengthRel: 52,providedInfo:36,nextSteps:24,didNotAch:19,noShow:12,cancelled:10,doNotTrack:14}, prev:236 },
  { name:'Open Bank Account', c:{closedBiz: 20,genOpp:13,strengthRel: 65,providedInfo:44,nextSteps:27,didNotAch:21,noShow:13,cancelled:11,doNotTrack:15}, prev:196 },
];

// ── HELPERS ───────────────────────────────────────────────────────────────────

const s = c => Object.values(c).reduce((a,b)=>a+b,0);
const pct = (n,t) => t ? (n/t*100).toFixed(1) : '0.0';
const fmt = n => Number(n).toLocaleString();

function deltaStr(curr, prev) {
  const d = ((curr-prev)/prev*100).toFixed(1);
  return (d>=0?'▲ +':'▼ ')+d+'%';
}
function deltaCls(curr,prev) { return curr>=prev?'delta-up':'delta-down'; }

// ── KPI RENDER ────────────────────────────────────────────────────────────────

function renderKPIs(rows) {
  const curr = rows.reduce((a,r)=>a+s(r.c),0);
  const prev = rows.reduce((a,r)=>a+r.prev,0);
  const doNotTrack = rows.reduce((a,r)=>a+(r.c.doNotTrack||0),0);
  const recorded = curr - doNotTrack;
  const recPct = pct(recorded,curr);
  const prevRecPct = 84.1;
  const recDiff = (parseFloat(recPct)-prevRecPct).toFixed(1);
  const recDiffStr = (recDiff>=0?'▲ +':'▼ ')+recDiff+'pp vs prior period';
  const recDiffCls = recDiff>=0?'up':'down';
  const dStr = deltaStr(curr,prev);
  const dCls = deltaCls(curr,prev);

  document.getElementById('kpi-row').innerHTML = `
    <div class="kpi-tile">
      <div class="kpi-tile-header">
        <span class="kpi-tile-label">Total Engagements</span>
        <span class="kpi-tile-menu">⋮</span>
      </div>
      <div class="kpi-tile-value">${fmt(curr)}</div>
      <div class="kpi-tile-delta ${dCls}">${dStr}</div>
      <div class="kpi-tile-sub">vs. ${fmt(prev)} prior period</div>
    </div>
    <div class="kpi-tile">
      <div class="kpi-tile-header">
        <span class="kpi-tile-label">Outcomes Recorded</span>
        <span class="kpi-tile-menu">⋮</span>
      </div>
      <div class="kpi-tile-value">${recPct}%</div>
      <div class="kpi-tile-delta ${recDiffCls}">${recDiffStr}</div>
      <div class="kpi-tile-sub">${fmt(recorded)} of ${fmt(curr)} engagements</div>
    </div>`;
}

// ── TABLE RENDER ──────────────────────────────────────────────────────────────

let sortState = {};

function buildHead(tableId, firstLabel, extraCols) {
  const offset = extraCols.length;
  const extraThs = extraCols.map((ec,i)=>
    `<th onclick="sortCol('${tableId}',${1+i})">${ec.label}</th>`).join('');
  const outcomeThs = OUTCOMES.map((o,i)=>
    `<th onclick="sortCol('${tableId}',${1+offset+i})">${o.label}</th>`).join('');
  document.querySelector(`#${tableId} thead`).innerHTML =
    `<tr><th onclick="sortCol('${tableId}',0)">${firstLabel}</th>${extraThs}${outcomeThs}</tr>`;
}

function buildBody(tableId, rows, firstKey, extraCols) {
  const tbody = document.querySelector(`#${tableId} tbody`);
  if (!rows.length) {
    const colCount = 1 + extraCols.length + OUTCOMES.length;
    tbody.innerHTML = `<tr><td colspan="${colCount}" class="empty-state">No data matches the current filters.</td></tr>`;
    return;
  }
  tbody.innerHTML = rows.map(row => {
    const total = s(row.c);
    const extraCells = extraCols.map(ec=>`<td>${row[ec.key]||''}</td>`).join('');
    const outcomeCells = OUTCOMES.map(o=>{
      const n = row.c[o.key]||0;
      const p = pct(n,total);
      return `<td class="oc" data-val="${p}"><span class="oc-pct">${p}%</span><span class="oc-n">${fmt(n)}</span></td>`;
    }).join('');
    return `<tr>
      <td class="name-cell">${row[firstKey]||row.name}</td>
      ${extraCells}
      ${outcomeCells}
    </tr>`;
  }).join('');
}

function sortCol(tableId, colIdx) {
  const key = `${tableId}-${colIdx}`;
  const prev = sortState[key]||'none';
  const dir = prev==='desc'?'asc':'desc';
  sortState = {};
  sortState[key] = dir;
  document.querySelectorAll(`#${tableId} thead th`).forEach((th,i)=>{
    th.classList.remove('sort-asc','sort-desc');
    if(i===colIdx) th.classList.add(dir==='asc'?'sort-asc':'sort-desc');
  });
  const tbody = document.querySelector(`#${tableId} tbody`);
  const trs = Array.from(tbody.querySelectorAll('tr'));
  trs.sort((a,b)=>{
    const ac = a.cells[colIdx], bc = b.cells[colIdx];
    const av = ac?.dataset.val || ac?.textContent.replace(/[^0-9.\-]/g,'') || '';
    const bv = bc?.dataset.val || bc?.textContent.replace(/[^0-9.\-]/g,'') || '';
    const an=parseFloat(av), bn=parseFloat(bv);
    if(!isNaN(an)&&!isNaN(bn)) return dir==='asc'?an-bn:bn-an;
    return dir==='asc'?av.localeCompare(bv):bv.localeCompare(av);
  });
  trs.forEach(tr=>tbody.appendChild(tr));
}

// ── FILTERS & RE-RENDER ───────────────────────────────────────────────────────

function applyFilters() {
  const sg  = document.getElementById('f-sg').value;
  const loc = document.getElementById('f-loc').value;
  const svc = document.getElementById('f-svc').value;

  // Location table
  const locRows = loc ? LOCATIONS.filter(r=>r.name===loc) : [...LOCATIONS];
  buildBody('loc-table', locRows.sort((a,b)=>s(b.c)-s(a.c)), 'name', []);

  // Staff Group table — filtered by location (staff at filtered location)
  let sgRows = [...STAFF_GROUPS];
  if (loc) {
    // Aggregate from staff members at this location
    const staffAtLoc = STAFF_MEMBERS.filter(m => m.location === loc);
    sgRows = STAFF_GROUPS.map(g => {
      const members = staffAtLoc.filter(m => m.group === g.name);
      if (!members.length) return null;
      const c = {};
      OUTCOMES.forEach(o => { c[o.key] = members.reduce((a,m)=>a+(m.c[o.key]||0),0); });
      const prev = members.reduce((a,m)=>a+m.prev,0);
      return { name: g.name, c, prev };
    }).filter(Boolean);
  }
  if (sg) sgRows = sgRows.filter(r=>r.name===sg);
  buildBody('sg-table', sgRows, 'name', []);

  // Staff Detail — filtered by group and/or location
  let staffRows = [...STAFF_MEMBERS];
  if (sg)  staffRows = staffRows.filter(m=>m.group===sg);
  if (loc) staffRows = staffRows.filter(m=>m.location===loc);
  staffRows.sort((a,b)=>s(b.c)-s(a.c));
  buildBody('staff-table', staffRows, 'name',
    [{ key:'group', label:'Staff Group' }, { key:'location', label:'Location' }]);

  // Service table
  const svcRows = svc ? SERVICES.filter(r=>r.name===svc) : [...SERVICES];
  buildBody('svc-table', svcRows.sort((a,b)=>s(b.c)-s(a.c)), 'name', []);

  // KPI: use all staff rows for the active filters (best proxy for engagement count)
  const kpiBase = staffRows.length ? staffRows : STAFF_MEMBERS;
  renderKPIs(kpiBase);
}

// ── INIT ──────────────────────────────────────────────────────────────────────

function init() {
  // Populate location dropdown
  const locSel = document.getElementById('f-loc');
  [...LOCATIONS].sort((a,b)=>a.name.localeCompare(b.name)).forEach(l=>{
    const o=document.createElement('option'); o.value=l.name; o.textContent=l.name; locSel.appendChild(o);
  });

  // Build table headers (static, set once)
  buildHead('loc-table',   'Location',   []);
  buildHead('sg-table',    'Staff Group',[]);
  buildHead('staff-table', 'Staff Name', [{ label:'Staff Group' },{ label:'Location' }]);
  buildHead('svc-table',   'Service',    []);

  applyFilters();
}

init();
</script>
</body>
</html>
